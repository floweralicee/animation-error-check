{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnimationErrorCheckOutput",
  "description": "Full output of the animation error check analysis pipeline",
  "type": "object",
  "properties": {
    "clip_id": {
      "type": "string",
      "description": "Filename or identifier for the analyzed clip"
    },
    "exercise_type": {
      "type": "string",
      "enum": ["auto", "bouncing_ball", "walk_cycle", "jump", "acting"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "fps": { "type": "number" },
        "duration_sec": { "type": "number" },
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "frame_count": { "type": "integer" }
      },
      "required": ["fps", "duration_sec", "width", "height", "frame_count"]
    },
    "analysis": {
      "type": "object",
      "properties": {
        "sampled_frames": { "type": "integer" },
        "largest_change_frames": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "average_brightness_range": {
          "type": "object",
          "properties": {
            "min": { "type": "number" },
            "max": { "type": "number" }
          },
          "required": ["min", "max"]
        }
      },
      "required": ["sampled_frames", "largest_change_frames", "average_brightness_range"]
    },
    "summary": {
      "type": "string",
      "description": "Human-readable summary of the analysis"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "frame_range": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 2,
            "maxItems": 2
          },
          "note": { "type": "string" }
        },
        "required": ["category", "severity", "frame_range", "note"]
      }
    },
    "confidence_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Honest notes about what was and wasn't measured"
    },
    "keyframe_paths": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Relative paths to extracted keyframe images"
    }
  },
  "required": ["clip_id", "exercise_type", "metadata", "analysis", "summary", "issues", "confidence_notes"]
}
