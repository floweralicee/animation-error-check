# Hana - Animation Error Check - Environment Variables

# Max upload size in bytes (default: 100MB)
MAX_UPLOAD_SIZE=104857600

# Number of frames to sample for analysis (default: 48)
SAMPLE_FRAME_COUNT=48

# Temp directory for uploads (default: ./temp_uploads)
UPLOAD_DIR=./temp_uploads

# --- MatAnyone2 Foreground Segmentation (optional) ---
# Path to cloned MatAnyone2 repo (https://github.com/pq-yang/MatAnyone2)
# If set, Hana will use MatAnyone2 for high-quality foreground isolation.
# If not set, falls back to temporal-diff segmentation (still works, less precise).
# MATANYONE2_DIR=/path/to/MatAnyone2

# Python executable with MatAnyone2 dependencies installed
# (conda activate matanyone2 && which python)
# MATANYONE2_PYTHON=/path/to/conda/envs/matanyone2/bin/python

# Future: Custom FFmpeg path (if not in system PATH)
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# Public site URL for email “result” links (no trailing slash). Falls back to RENDER_EXTERNAL_URL, VERCEL_URL, or localhost.
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- PostHog (optional; omit to disable analytics) ---
# Project API key from PostHog project settings
# NEXT_PUBLIC_POSTHOG_KEY=phc_...

# Ingest API host — must match your PostHog region (US or EU)
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Resend (optional; email summary after analysis) ---
# RESEND_API_KEY=re_...
# Optional; defaults to Hana <alice@animclaw.com> in code if unset (domain must be verified in Resend).
# RESEND_FROM="Hana <alice@animclaw.com>"

# --- Supabase (optional; audit table + async analysis) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (server only, never expose to client)
# SUPABASE_STORAGE_BUCKET=analysis-videos

# --- Inngest (optional; background analysis — register app at inngest.com) ---
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=signkey-...

# Client: set to "true" to use POST /api/analyze/jobs + polling (requires Supabase + Inngest)
# NEXT_PUBLIC_USE_ASYNC_ANALYSIS=false
