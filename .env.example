# Animation Error Check - Environment Variables

# Max upload size in bytes (default: 100MB)
MAX_UPLOAD_SIZE=104857600

# Number of frames to sample for analysis (default: 24)
SAMPLE_FRAME_COUNT=24

# Temp directory for uploads (default: ./temp_uploads)
UPLOAD_DIR=./temp_uploads

# Future: OpenAI API key for LLM-based critique
# OPENAI_API_KEY=sk-...

# Future: Custom FFmpeg path (if not in system PATH)
# FFMPEG_PATH=/usr/local/bin/ffmpeg
